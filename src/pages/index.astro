---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { HOME, SITE, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";

const aiPosts = (await getCollection("ai-experiments"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const d2cPosts = (await getCollection("disconnect-to-connect"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-20">

        <!-- Hero -->
        <section class="animate flex flex-col items-center text-center">
          <h1 class="hero-name">
            Rado Pavelko
          </h1>
          <p class="hero-subtitle">
            Sharing my AI experiments and how to disconnect to connect
          </p>
          <div class="hero-portrait mt-10">
            <img
              src="/portrait.jpg"
              alt="Rado Pavelko"
              class="mx-auto max-h-[520px] w-auto object-contain"
              onerror="this.style.display='none'"
            />
          </div>
        </section>

        <!-- AI Experiments preview -->
        <section class="animate space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="text-lg font-semibold tracking-wide text-black dark:text-white">
              AI Experiments
            </h2>
            <Link href="/ai-experiments">See all</Link>
          </div>
          <ul class="not-prose flex flex-col gap-4">
            {aiPosts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </section>

        <!-- Disconnect to Connect preview -->
        <section class="animate space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="text-lg font-semibold tracking-wide text-black dark:text-white">
              Disconnect to Connect
            </h2>
            <Link href="/disconnect-to-connect">See all</Link>
          </div>
          <ul class="not-prose flex flex-col gap-4">
            {d2cPosts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))}
          </ul>
        </section>

        <!-- Connect -->
        <section class="animate space-y-4">
          <h2 class="text-lg font-semibold tracking-wide text-black dark:text-white">
            Let's Connect
          </h2>
          <ul class="not-prose flex flex-wrap gap-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="flex gap-x-2 text-nowrap">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link
                href={`mailto:${SITE.EMAIL}`}
                aria-label={`Email ${SITE.TITLE}`}
              >
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </section>

      </div>
    </aside>
  </Container>
</Layout>
